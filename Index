  const a = document.createElement('a'); a.href = URL.createObjectURL(new Blob([doc], { type: 'text/plain' })); a.download = `OLS_Weekly_Report_${new Date().toISOString().slice(0, 10)}.txt`; a.click(); showToast('✓ Report exported — open in Word or Docs');
}

