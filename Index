<script>
// ── CONFIG & STATE ──────────────────────────────────────────
const DEFAULT_API_URL = 'https://script.google.com/macros/s/AKfycbz1bknZfqxJXT0L_RTBAz4w2ms3RVTy5doaZZVaaqYaIU4xO2NFjKdOxIUJnJIAS2qu1A/exec'; // Replace with your deployed Web App URL
let gsConfig = JSON.parse(localStorage.getItem('ols_gs') || '{}');
if (!gsConfig.url) {
  gsConfig.url = DEFAULT_API_URL;
  localStorage.setItem('ols_gs', JSON.stringify(gsConfig));
}
let currentUser = JSON.parse(sessionStorage.getItem('ols_user') || '{}');
let projects = [], tenders = [], operations = [], history = [], users = [];
let editingId = null, viewingId = null, viewingType = null;
let projFilter = 'all', tendFilter = 'all', opsFilter = 'all';
let currentPage = 'dashboard';
let lockCountdownTimer = null;
let currentLockItemId = null;

const SVC_COLORS = { Trucking: '#1D9E75', Warehousing: '#378ADD', Technology: '#7F77DD', Advisory: '#BA7517', Distribution: '#D4537E', Other: '#888780' };
const SVC_BADGE = { Trucking: 'sb-trucking', Warehousing: 'sb-warehouse', Technology: 'sb-tech', Advisory: 'sb-advisory', Distribution: 'sb-distribution', Other: 'sb-other' };
const STATUS_BADGE = { 'On Track': 'b-ontrack', Waiting: 'b-waiting', Blocked: 'b-blocked', Completed: 'b-completed', Upcoming: 'b-waiting', Submitted: 'b-submitted', Negotiating: 'b-negotiating', Won: 'b-won', Lost: 'b-lost' };
const TEND_TYPE_BADGE = { RFQ: 'b-rfq', RFX: 'b-rfx', 'Direct Negotiation': 'b-direct' };

// ── AUTH & SESSION ──────────────────────────────────────────
function saveSession(user) {
  sessionStorage.setItem('ols_user', JSON.stringify(user));
  currentUser = user;
  updateUserInfo();
}
function getSession() {
  return currentUser;
}
function isLoggedIn() {
  return !!currentUser.userId;
}
function isAdmin() {
  return currentUser.role === 'admin';
}
function isEditor() {
  return currentUser.role === 'editor' || isAdmin();
}
function isViewer() {
  return currentUser.role === 'viewer';
}
function logout() {
  sessionStorage.removeItem('ols_user');
  location.reload();
}
function updateUserInfo() {
  const display = document.getElementById('user-display');
  if (isLoggedIn()) {
    display.textContent = `${currentUser.name} (${currentUser.role})`;
  } else {
    display.textContent = 'Guest';
  }
}

async function handleLogin() {
  const code = document.getElementById('login-code').value.trim();
  const errorEl = document.getElementById('login-error');
  if (!code) return;
  errorEl.style.display = 'none';
  try {
    const resp = await apiPost('login', { code });
    if (resp.success) {
      saveSession(resp);
      document.getElementById('login-screen').style.display = 'none';
      showToast(`Welcome, ${currentUser.name}!`);
      loadFromSheets(false);
    } else {
      errorEl.textContent = resp.error || 'Invalid code.';
      errorEl.style.display = 'block';
    }
  } catch (err) {
    errorEl.textContent = 'Connection error. Please try again.';
    errorEl.style.display = 'block';
  }
}

// ── API HELPERS ─────────────────────────────────────────────
async function apiGet(action, params = {}) {
  const url = gsConfig.url;
  if (!url) throw new Error('No API URL configured');
  const query = new URLSearchParams({ action, code: currentUser.code || '', ...params }).toString();
  const res = await fetch(`${url}?${query}`);
  const data = await res.json();
  if (data.success === false) throw new Error(data.error || 'API error');
  return data;
}
async function apiPost(action, body = {}) {
  const url = gsConfig.url;
  if (!url) throw new Error('No API URL configured');
  const res = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ action, code: currentUser.code || '', ...body })
  });
  const data = await res.json();
  if (data.success === false) throw new Error(data.error || 'API error');
  return data;
}

// ── DATA LOADING & SYNC ────────────────────────────────────
async function loadFromSheets(isConnect) {
  if (!gsConfig.url) { showToast('⚠ Configure API URL first'); return; }
  if (isConnect) showToast('Loading data…', 3000);
  try {
    const json = await apiGet('getData');
    projects = json.projects || [];
    tenders = json.tenders || [];
    operations = json.operations || [];
    history = json.history || [];
    if (isAdmin()) {
      const usersData = await apiGet('getUsers');
      users = usersData || [];
    }
    gsConfig.connected = true;
    localStorage.setItem('ols_gs', JSON.stringify(gsConfig));
    updateConnStatus();
    renderDashboard();
    if (currentPage === 'projects') renderProjects();
    if (currentPage === 'tenders') renderTenders();
    if (currentPage === 'operations') renderOperations();
    if (currentPage === 'history') renderHistory();
    if (isConnect) showToast('✓ Connected! Data loaded.');
  } catch (err) {
    gsConfig.connected = false;
    localStorage.setItem('ols_gs', JSON.stringify(gsConfig));
    updateConnStatus();
    if (isConnect) showToast('✗ Failed: ' + err.message, 5000);
    console.error('Load error:', err);
  }
}
async function syncSheets() {
  if (!gsConfig.url || !isEditor()) return;
  try {
    await apiPost('sync', { projects, tenders, operations });
  } catch (err) {
    console.warn('Sync failed:', err.message);
    showToast('⚠ Sync failed. Check connection.');
  }
}

// ── NAVIGATION ──────────────────────────────────────────────
function showPage(page, el) {
  currentPage = page;
  document.querySelectorAll('[id^="page-"]').forEach(p => p.style.display = 'none');
  document.getElementById('page-' + page).style.display = '';
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  if (el) el.classList.add('active');
  const titles = { dashboard: 'Dashboard', projects: 'Projects', tenders: 'Tenders', operations: 'Operations', report: 'Weekly Report', history: 'History', settings: 'Settings' };
  const subs = { dashboard: 'Overview', projects: 'Strategic workstreams', tenders: 'RFQ/RFX tracking', operations: 'Recurring activities', report: 'Generate weekly doc', history: 'Edit log', settings: 'Connection & Users' };
  document.getElementById('topbar-title').textContent = titles[page] || page;
  document.getElementById('topbar-sub').textContent = subs[page] || '';
  document.getElementById('topbar-action-btn').textContent = page === 'tenders' ? '+ New Tender' : page === 'operations' ? '+ New Operation' : '+ New Entry';
  document.getElementById('topbar-action-btn').onclick = page === 'tenders' ? openAddTender : page === 'operations' ? openAddOperation : openAddProject;
  if (page === 'dashboard') renderDashboard();
  if (page === 'projects') renderProjects();
  if (page === 'tenders') renderTenders();
  if (page === 'operations') renderOperations();
  if (page === 'report') renderReport();
  if (page === 'history') renderHistory();
  if (page === 'settings') renderSettings();
}

// ── RENDERING ───────────────────────────────────────────────
function renderDashboard() {
  const clients = [...new Set(projects.map(p => p.client))].length;
  const openTend = tenders.filter(t => !['Won', 'Lost'].includes(t.status)).length;
  const now = new Date(); now.setHours(0, 0, 0, 0);
  const we = new Date(now); we.setDate(we.getDate() + 7);
  const dueWeek = [...projects, ...tenders, ...operations].filter(x => { if (!x.deadline) return false; const d = new Date(x.deadline); d.setHours(0, 0, 0, 0); return d >= now && d <= we; }).length;
  const blocked = projects.filter(p => p.status === 'Blocked').length + operations.filter(o => o.status === 'Blocked').length;
  document.getElementById('d-clients').textContent = clients;
  document.getElementById('d-tenders').textContent = openTend;
  document.getElementById('d-week').textContent = dueWeek;
  document.getElementById('d-blocked').textContent = blocked;
  document.getElementById('nb-proj').textContent = projects.length;
  document.getElementById('nb-tend').textContent = tenders.length;
  document.getElementById('nb-ops').textContent = operations.length;
  document.getElementById('nb-hist').textContent = history.length;
  
  // Portfolio Health
  const total = projects.length + operations.length;
  let healthPct = 0;
  if (total > 0) {
    healthPct = (blocked / total) * 100;
  }
  const healthBadge = document.getElementById('health-badge');
  if (healthPct >= 30) {
    healthBadge.className = 'health-badge h-unhealthy';
    healthBadge.textContent = `● Unhealthy (${Math.round(healthPct)}% blocked)`;
  } else if (healthPct >= 15) {
    healthBadge.className = 'health-badge h-risk';
    healthBadge.textContent = `● At Risk (${Math.round(healthPct)}% blocked)`;
  } else {
    healthBadge.className = 'health-badge h-healthy';
    healthBadge.textContent = `● Healthy (${Math.round(healthPct)}% blocked)`;
  }
  
  renderDonutChart();
  renderPipelineBars();
  
  // Focus List
  let focusItems = [
    ...projects.filter(p => p.status === 'Blocked' || isThisWeek(p.deadline)),
    ...operations.filter(o => o.status === 'Blocked' || isThisWeek(o.deadline)),
    ...tenders.filter(t => isThisWeek(t.deadline))
  ];
  const fl = document.getElementById('dash-focus-list');
  if (!focusItems.length) {
    fl.innerHTML = '<div class="empty-box"><h3>All clear</h3><p>No deadlines within 7 days and no blocked items</p></div>';
    return;
  }
  fl.innerHTML = `<div class="sheet-table"><div style="display:grid;grid-template-columns:160px 1fr 110px 100px;" class="sheet-head-row"><div class="sh-cell">Client</div><div class="sh-cell">Topic</div><div class="sh-cell">Deadline</div><div class="sh-cell">Status</div></div>${focusItems.map(item => {
    const days = daysLeft(item.deadline);
    const dlClass = days !== null && days <= 3 ? 'dl-urgent' : 'dl-text';
    const dlText = item.deadline ? (days < 0 ? `${Math.abs(days)}d overdue` : days === 0 ? 'Today' : days + 'd left') : '—';
    const sc = STATUS_BADGE[item.status] || 'b-waiting';
    const type = item.workstream ? 'project' : item.milestones ? 'tender' : 'operation';
    return `<div style="display:grid;grid-template-columns:160px 1fr 110px 100px;" class="sheet-row-item" onclick="openDetail('${item.id}','${type}')"><div class="sd-cell"><span style="font-weight:600;">${escH(item.client)}</span></div><div class="sd-cell"><span class="sd-cell-text">${escH(item.workstream || item.type || '')}</span></div><div class="sd-cell"><span class="${dlClass}">${dlText}</span></div><div class="sd-cell"><span class="badge ${sc}">${item.status}</span></div></div>`;
  }).join('')}</div>`;
}

function renderDonutChart() {
  const canvas = document.getElementById('donut-chart');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  canvas.width = 110 * dpr; canvas.height = 110 * dpr;
  canvas.style.width = '110px'; canvas.style.height = '110px';
  ctx.scale(dpr, dpr);
  const statusDefs = [{ key: 'On Track', color: '#1D9E75', label: 'On Track' }, { key: 'Waiting', color: '#378ADD', label: 'Waiting' }, { key: 'Blocked', color: '#c23a3a', label: 'Blocked' }, { key: 'Completed', color: '#5DCAA5', label: 'Completed' }];
  const allItems = [...projects, ...operations];
  const counts = statusDefs.map(s => ({ ...s, count: allItems.filter(p => p.status === s.key).length }));
  const total = allItems.length;
  document.getElementById('donut-total').textContent = total;
  const cx = 55, cy = 55, r = 44, inner = 28;
  ctx.clearRect(0, 0, 110, 110);
  if (!total) {
    ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2); ctx.strokeStyle = '#222'; ctx.lineWidth = r - inner; ctx.stroke();
    document.getElementById('donut-legend').innerHTML = '<div style="font-size:12px;color:#666;">No items yet</div>';
    return;
  }
  document.getElementById('donut-legend').innerHTML = counts.map(s => `<div class="legend-item"><div class="legend-dot" style="background:${s.color};"></div><div class="legend-label">${s.label}</div><div class="legend-val">${s.count}</div></div>`).join('');
  animateDonut(ctx, cx, cy, r, inner, counts.filter(s => s.count > 0), total);
}

function animateDonut(ctx, cx, cy, r, inner, slices, total) {
  const duration = 900; const start = performance.now();
  function draw(now) {
    const progress = Math.min((now - start) / duration, 1);
    const ease = 1 - Math.pow(1 - progress, 3);
    const gap = 0.04; let startAngle = -Math.PI / 2;
    ctx.clearRect(0, 0, 110, 110);
    slices.forEach(s => {
      const fullSlice = (s.count / total) * (Math.PI * 2) - (gap * 2);
      const slice = fullSlice * ease;
      ctx.beginPath(); ctx.arc(cx, cy, r, startAngle + gap, startAngle + gap + slice); ctx.arc(cx, cy, inner, startAngle + gap + slice, startAngle + gap, true); ctx.closePath(); ctx.fillStyle = s.color; ctx.fill();
      startAngle += (s.count / total) * (Math.PI * 2);
    });
    if (progress < 1) requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
}

function renderPipelineBars() {
  const el = document.getElementById('pipeline-bars'); if (!el) return;
  const stages = [{ key: 'Upcoming', color: '#378ADD', label: 'Upcoming' }, { key: 'Submitted', color: '#7F77DD', label: 'Submitted' }, { key: 'Negotiating', color: '#BA7517', label: 'Negotiating' }, { key: 'Won', color: '#1D9E75', label: 'Won' }, { key: 'Lost', color: '#c23a3a', label: 'Lost' }];
  const counts = stages.map(s => ({ ...s, count: tenders.filter(t => t.status === s.key).length }));
  const max = Math.max(...counts.map(s => s.count), 1);
  if (!tenders.length) { el.innerHTML = '<div style="font-size:12px;color:#666;text-align:center;padding:20px 0;">No tenders yet</div>'; return; }
  el.innerHTML = counts.map(s => `<div class="pipe-row"><div class="pipe-label">${s.label}</div><div class="pipe-track"><div class="pipe-fill" style="background:${s.color};" data-pct="${Math.round(s.count / max * 100)}"></div></div><div class="pipe-count">${s.count}</div></div>`).join('');
  setTimeout(() => { el.querySelectorAll('.pipe-fill').forEach(bar => { bar.style.width = bar.dataset.pct + '%'; }); }, 80);
}

function setProjFilter(f, el) { projFilter = f; document.querySelectorAll('#page-projects .filter-pill').forEach(p => p.classList.remove('active')); el.classList.add('active'); renderProjects(); }
function renderProjects() {
  const q = (document.getElementById('proj-search') || {}).value?.toLowerCase() || '';
  let list = [...projects];
  if (projFilter !== 'all' && projFilter !== 'Blocked') list = list.filter(p => p.service === projFilter);
  if (projFilter === 'Blocked') list = list.filter(p => p.status === 'Blocked');
  if (q) list = list.filter(p => (p.client + p.workstream + p.service + p.owner).toLowerCase().includes(q));
  const board = document.getElementById('proj-board');
  if (!list.length) { board.innerHTML = '<div class="empty-box"><h3>No entries found</h3><p>Add a new project or adjust filters</p></div>'; return; }
  const grouped = {};
  list.forEach(p => { if (!grouped[p.client]) grouped[p.client] = []; grouped[p.client].push(p); });
  board.innerHTML = Object.keys(grouped).map(client => {
    const rows = grouped[client]; const svc = rows[0].service; const color = SVC_COLORS[svc] || '#888';
    return `<div class="sheet-wrap"><div class="sheet-client-header"><div class="sheet-client-dot" style="background:${color};"></div><span class="sheet-client-name">${escH(client)}</span><span class="sheet-client-meta">${rows.length} workstream${rows.length !== 1 ? 's' : ''}</span></div><div class="sheet-table"><div class="proj-head sheet-head-row"><div class="sh-cell">Workstream</div><div class="sh-cell">Service</div><div class="sh-cell">Last Week</div><div class="sh-cell">This Week</div><div class="sh-cell">Owner</div><div class="sh-cell">Status</div></div>${rows.map(p => buildProjRow(p, color)).join('')}</div></div>`;
  }).join('');
}
function buildProjRow(p, color) {
  const sc = STATUS_BADGE[p.status] || 'b-waiting'; const sb = SVC_BADGE[p.service] || 'sb-advisory';
  return `<div class="proj-row sheet-row-item" onclick="openDetail('${p.id}','project')"><div class="sd-cell sd-cell-name"><div class="sd-cell-bar" style="background:${color};"></div><div class="sd-cell-title">${escH(p.workstream)}</div>${p.dates ? `<div class="sd-cell-sub">${escH(p.dates)}</div>` : ''}</div><div class="sd-cell"><span class="sb ${sb}">${escH(p.service)}</span></div><div class="sd-cell"><span class="week-cell">${escH(p.lastweek || '—')}</span></div><div class="sd-cell"><span class="week-cell">${escH(p.thisweek || '—')}</span></div><div class="sd-cell" style="font-size:12.5px;color:var(--text-2);">${escH(p.owner || '—')}</div><div class="sd-cell"><span class="badge ${sc}">${p.status}</span></div></div>`;
}

function setTendFilter(f, el) { tendFilter = f; document.querySelectorAll('#page-tenders .filter-pill').forEach(p => p.classList.remove('active')); el.classList.add('active'); renderTenders(); }
function renderTenders() {
  const q = (document.getElementById('tend-search') || {}).value?.toLowerCase() || '';
  let list = [...tenders];
  if (tendFilter !== 'all') list = list.filter(t => t.status === tendFilter);
  if (q) list = list.filter(t => (t.client + t.type + t.owner).toLowerCase().includes(q));
  const board = document.getElementById('tend-board');
  if (!list.length) { board.innerHTML = '<div class="empty-box" style="border:none;box-shadow:none;"><h3>No tenders found</h3><p>Add a tender or adjust filter</p></div>'; return; }
  board.innerHTML = list.map(t => buildTendRow(t)).join('');
}
function buildTendRow(t) {
  const sc = STATUS_BADGE[t.status] || 'b-waiting'; const tc = TEND_TYPE_BADGE[t.type] || 'b-rfq';
  const milestones = (t.milestones || []).slice(0, 3).map(m => { const days = daysLeft(m.date); const cls = days !== null && days < 0 ? 'dl-overdue' : days !== null && days <= 3 ? 'dl-urgent' : 'dl-text'; return `<div style="font-size:11px;line-height:1.6;"><span style="color:var(--text-2);">${escH(m.label)}: </span><span class="${cls}">${fmtDate(m.date)}</span></div>`; }).join('');
  const linkHtml = t.link ? `<a class="sd-cell-link" href="${escH(t.link)}" target="_blank" rel="noopener" onclick="event.stopPropagation()">↗ Document</a>` : '<span style="color:var(--text-3);font-size:12px;">—</span>';
  return `<div class="tend-row sheet-row-item" onclick="openDetail('${t.id}','tender')"><div class="sd-cell sd-cell-name"><div class="sd-cell-bar" style="background:var(--red);"></div><div class="sd-cell-title">${escH(t.client)}</div></div><div class="sd-cell"><span class="badge ${tc}">${escH(t.type)}</span></div><div class="sd-cell"><div>${milestones || '<span style="color:var(--text-3);font-size:12px;">No milestones</span>'}</div></div><div class="sd-cell">${linkHtml}</div><div class="sd-cell" style="font-size:12.5px;color:var(--text-2);">${escH(t.owner || '—')}</div><div class="sd-cell"><span class="badge ${sc}">${t.status}</span></div></div>`;
}

function setOpsFilter(f, el) { opsFilter = f; document.querySelectorAll('#page-operations .filter-pill').forEach(p => p.classList.remove('active')); el.classList.add('active'); renderOperations(); }
function renderOperations() {
  const q = (document.getElementById('ops-search') || {}).value?.toLowerCase() || '';
  let list = [...operations];
  if (opsFilter !== 'all' && opsFilter !== 'Blocked') list = list.filter(o => o.service === opsFilter);
  if (opsFilter === 'Blocked') list = list.filter(o => o.status === 'Blocked');
  if (q) list = list.filter(o => (o.client + o.workstream + o.service + o.owner).toLowerCase().includes(q));
  const board = document.getElementById('ops-board');
  if (!list.length) { board.innerHTML = '<div class="empty-box"><h3>No entries found</h3><p>Add a new operation or adjust filters</p></div>'; return; }
  const grouped = {};
  list.forEach(o => { if (!grouped[o.client]) grouped[o.client] = []; grouped[o.client].push(o); });
  board.innerHTML = Object.keys(grouped).map(client => {
    const rows = grouped[client]; const svc = rows[0].service; const color = SVC_COLORS[svc] || '#888';
    return `<div class="sheet-wrap"><div class="sheet-client-header"><div class="sheet-client-dot" style="background:${color};"></div><span class="sheet-client-name">${escH(client)}</span><span class="sheet-client-meta">${rows.length} activity${rows.length !== 1 ? 'ies' : ''}</span></div><div class="sheet-table"><div class="ops-head sheet-head-row"><div class="sh-cell">Activity</div><div class="sh-cell">Service</div><div class="sh-cell">Last Week</div><div class="sh-cell">This Week</div><div class="sh-cell">Owner</div><div class="sh-cell">Status</div></div>${rows.map(o => buildOpsRow(o, color)).join('')}</div></div>`;
  }).join('');
}
