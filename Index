// ── LOCK SYSTEM ─────────────────────────────────────────────
async function acquireLock(itemId) {
  if (!gsConfig.url || !currentUser.userId) return true;
  try {
    const resp = await apiPost('acquireLock', { itemId, userId: currentUser.userId, userName: currentUser.name });
    if (resp.result === 'locked') {
      showLockOverlay(resp.lockedBy, resp.expiresIn, itemId);
      return false;
    }
    currentLockItemId = itemId;
    return true;
  } catch (e) {
    return true;
  }
}
async function releaseLock(itemId) {
  if (!gsConfig.url || !currentUser.userId || !itemId) return;
  clearInterval(lockCountdownTimer);
  currentLockItemId = null;
  try {
    await apiPost('releaseLock', { itemId, userId: currentUser.userId });
  } catch (e) {}
}
function showLockOverlay(lockedBy, expiresIn, itemId) {
  document.getElementById('lock-email-display').textContent = lockedBy;
  document.getElementById('lock-overlay').style.display = 'flex';
  let secs = expiresIn;
  document.getElementById('lock-countdown').textContent = secs + 's';
  clearInterval(lockCountdownTimer);
  lockCountdownTimer = setInterval(() => {
    secs--;
    if (secs <= 0) {
      clearInterval(lockCountdownTimer);
      document.getElementById('lock-overlay').style.display = 'none';
      showToast('Lock expired — you can now edit');
    } else {
      document.getElementById('lock-countdown').textContent = secs + 's';
    }
  }, 1000);
}
function dismissLock() {
  clearInterval(lockCountdownTimer);
  document.getElementById('lock-overlay').style.display = 'none';
}

// ── UTILITIES ───────────────────────────────────────────────
function genId() { return '_' + Math.random().toString(36).substr(2, 9); }
function escH(s = '') { return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }
function fmtDate(ds) { if (!ds) return '—'; return new Date(ds).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }); }
function daysLeft(ds) { if (!ds) return null; const d = new Date(ds), n = new Date(); d.setHours(0, 0, 0, 0); n.setHours(0, 0, 0, 0); return Math.round((d - n) / 86400000); }
function isThisWeek(ds) { if (!ds) return false; const d = new Date(ds), n = new Date(), we = new Date(); d.setHours(0, 0, 0, 0); n.setHours(0, 0, 0, 0); we.setDate(we.getDate() + 7); we.setHours(0, 0, 0, 0); return d >= n && d <= we; }
function showToast(msg, dur = 2600) { const t = document.getElementById('toast'); t.textContent = msg; t.classList.add('show'); setTimeout(() => t.classList.remove('show'), dur); }
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
  if ((id === 'proj-modal' || id === 'tend-modal' || id === 'ops-modal') && editingId) {
    releaseLock(editingId);
  }
  editingId = null;
}
function overlayClose(e, id) { if (e.target.id === id) closeModal(id); }
function exportCSV() {
  const headers = ['Type', 'Client', 'Workstream/TenderType/Activity', 'Service', 'Owner', 'Status', 'This Week', 'Deadline', 'Link'];
  const rows = [
    ...projects.map(p => ['Project', p.client, p.workstream, p.service, p.owner || '', p.status, `"${(p.thisweek || '').replace(/"/g, '""')}"`, p.deadline || '', p.link || '']),
    ...tenders.map(t => ['Tender', t.client, t.type, '—', t.owner || '', t.status, '', t.deadline || '', t.link || '']),
    ...operations.map(o => ['Operation', o.client, o.workstream, o.service, o.owner || '', o.status, `"${(o.thisweek || '').replace(/"/g, '""')}"`, o.deadline || '', o.link || ''])
  ];
  const csv = [headers, ...rows].map(r => r.join(',')).join('\n');
  const a = document.createElement('a'); a.href = URL.createObjectURL(new Blob([csv], { type: 'text/csv' })); a.download = `OLS_Hub_${new Date().toISOString().slice(0, 10)}.csv`; a.click(); showToast('✓ Exported as CSV');
}
function computeSHA256(text) {
  // Simple SHA-256 implementation for frontend code generation preview
  // In production, use crypto.subtle or backend hashing
  return '[HASHED_BY_BACKEND]';
}

// ── INIT ────────────────────────────────────────────────────
const APPS_SCRIPT_CODE = `// OLS Project-Ops - Apps Script
// Replace SPREADSHEET_ID with your Sheet ID
var SPREADSHEET_ID = 'YOUR_SHEET_ID_HERE';
var LOCK_TIMEOUT_MS = 120000;
var MAX_HISTORY = 50;

function doPost(e) {
  try {
    var data = JSON.parse(e.postData.contents);
    var ss = SpreadsheetApp.openById(SPREADSHEET_ID);
    
    if (data.action === 'sync') {
      _upsertSheet(ss, 'Projects', data.projects, ['ID','Client','Workstream','Service','Owner','Region','Status','Last Week','This Week','Dates','Deadline','Link','Notes','Updated']);
      _upsertSheet(ss, 'Tenders', data.tenders, ['ID','Client','Type','Owner','Status','Link','Notes','Milestones','Deadline','Updated']);
      _upsertSheet(ss, 'Operations', data.operations, ['ID','Client','Workstream','Service','Owner','Region','Status','Last Week','This Week','Dates','Deadline','Link','Notes','Updated']);
    }
    else if (data.action === 'acquireLock') {
      return _acquireLock(ss, data.itemId, data.userId, data.userName);
    }
    else if (data.action === 'releaseLock') {
      _releaseLock(ss, data.itemId, data.userId);
    }
    else if (data.action === 'logHistory') {
      _logHistory(ss, data);
    }
    else if (data.action === 'manageUsers') {
      _manageUsers(ss, data.users);
    }
    return ContentService.createTextOutput(JSON.stringify({result:'ok'})).setMimeType(ContentService.MimeType.JSON);
  } catch(err) {
    return ContentService.createTextOutput(JSON.stringify({result:'error',message:err.toString()})).setMimeType(ContentService.MimeType.JSON);
  }
}

function doGet(e) {
  try {
    var ss = SpreadsheetApp.openById(SPREADSHEET_ID);
    var action = e.parameter.action;
    
    if (action === 'health') {
      return ContentService.createTextOutput(JSON.stringify({status:'OK'})).setMimeType(ContentService.MimeType.JSON);
    }
    
    if (action === 'getData') {
      return ContentService.createTextOutput(JSON.stringify({
        result:'ok',
        projects:_getSheetData(ss,'Projects'),
        tenders:_getSheetData(ss,'Tenders'),
        operations:_getSheetData(ss,'Operations'),
        history:_getSheetData(ss,'History')
      })).setMimeType(ContentService.MimeType.JSON);
    }
    
    if (action === 'getUsers') {
      return ContentService.createTextOutput(JSON.stringify(_getUsers(ss))).setMimeType(ContentService.MimeType.JSON);
    }
    
    return ContentService.createTextOutput(JSON.stringify({result:'error',message:'Unknown action'})).setMimeType(ContentService.MimeType.JSON);
  } catch(err) {
    return ContentService.createTextOutput(JSON.stringify({result:'error',message:err.toString()})).setMimeType(ContentService.MimeType.JSON);
  }
}

function _upsertSheet(ss, tabName, items, headers) {
  var sheet = ss.getSheetByName(tabName);
  if (!sheet) {
    sheet = ss.insertSheet(tabName);
    sheet.appendRow(headers);
  }
  if (!items || items.length === 0) return;
  
  var data = sheet.getDataRange().getValues();
  var idMap = {};
  for (var i = 1; i < data.length; i++) {
    if (data[i][0]) idMap[data[i][0]] = i + 1;
  }
  
  var now = new Date();
  for (var j = 0; j < items.length; j++) {
    var item = items[j];
    var row = [];
    for (var k = 0; k < headers.length; k++) {
      var key = headers[k].toLowerCase().replace(/ /g, '');
      var val = item[key];
      if (key === 'updated') val = now;
      if (typeof val === 'number' && val > 9999999999) val = new Date(val);
      row.push(val || '');
    }
    
    if (idMap[item.id]) {
      sheet.getRange(idMap[item.id], 1, 1, row.length).setValues([row]);
    } else {
      sheet.appendRow(row);
    }
  }
}

function _getSheetData(ss, tabName) {
  var sheet = ss.getSheetByName(tabName);
  if (!sheet || sheet.getLastRow() <= 1) return [];
  var data = sheet.getDataRange().getValues();
  var headers = data[0];
  var rows = [];
  for (var i = 1; i < data.length; i++) {
    if (!data[i][0]) continue;
    var obj = {};
    for (var j = 0; j < headers.length; j++) {
      var key = headers[j].toLowerCase().replace(/ /g, '');
      var val = data[i][j];
      if (val instanceof Date) val = val.toISOString();
      obj[key] = val;
    }
    rows.push(obj);
  }
  return rows;
}

function _acquireLock(ss, itemId, userId, userName) {
  var sheet = ss.getSheetByName('EditLocks');
  if (!sheet) {
    sheet = ss.insertSheet('EditLocks');
    sheet.appendRow(['ItemId','UserId','UserName','Timestamp']);
  }
  var now = new Date().getTime();
  var data = sheet.getDataRange().getValues();
  for (var i = 1; i < data.length; i++) {
    if (data[i][0] === itemId) {
      var lockTime = new Date(data[i][3]).getTime();
      var age = now - lockTime;
      if (age < LOCK_TIMEOUT_MS && data[i][1] !== userId) {
        return ContentService.createTextOutput(JSON.stringify({result:'locked',lockedBy:data[i][2],expiresIn:Math.ceil((LOCK_TIMEOUT_MS-age)/1000)})).setMimeType(ContentService.MimeType.JSON);
      }
      sheet.deleteRow(i + 1);
      break;
    }
  }
  sheet.appendRow([itemId, userId, userName, new Date()]);
  return ContentService.createTextOutput(JSON.stringify({result:'ok'})).setMimeType(ContentService.MimeType.JSON);
}

function _releaseLock(ss, itemId, userId) {
  var sheet = ss.getSheetByName('EditLocks');
  if (!sheet) return;
  var data = sheet.getDataRange().getValues();
  for (var i = data.length - 1; i >= 1; i--) {
    if (data[i][0] === itemId && data[i][1] === userId) {
      sheet.deleteRow(i + 1);
    }
  }
}

function _logHistory(ss, data) {
  var sheet = ss.getSheetByName('History');
  if (!sheet) {
    sheet = ss.insertSheet('History');
    sheet.appendRow(['Timestamp','UserId','UserName','Action','Type','ItemId','Client','Summary']);
  }
  var row = [new Date(), data.userId, data.userName, data.histAction, data.itemType, data.itemId, data.client, data.summary];
  sheet.insertRowAfter(1);
  sheet.getRange(2, 1, 1, row.length).setValues([row]);
  var max = MAX_HISTORY + 1;
  if (sheet.getLastRow() > max) sheet.deleteRows(max + 1, sheet.getLastRow() - max);
}

function _manageUsers(ss, usersList) {
  var sheet = ss.getSheetByName('Users');
  if (!sheet) {
    sheet = ss.insertSheet('Users');
    sheet.appendRow(['UserId','CodeHash','Role','Name','Email','Active']);
  }
  if (sheet.getLastRow() > 1) sheet.deleteRows(2, sheet.getLastRow() - 1);
  for (var i = 0; i < usersList.length; i++) {
    var u = usersList[i];
    sheet.appendRow([u.userId, u.codeHash, u.role, u.name, u.email, u.active ? 'TRUE' : 'FALSE']);
  }
}

function _getUsers(ss) {
  var sheet = ss.getSheetByName('Users');
  if (!sheet) return [];
  var data = sheet.getDataRange().getValues();
  var users = [];
  for (var i = 1; i < data.length; i++) {
    users.push({userId:data[i][0],role:data[i][2],name:data[i][3],email:data[i][4],active:data[i][5]});
  }
  return users;
}`;

