<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OLS Project-Ops</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0A0A0A; --surface:#141414; --border:#222; --border-md:#2A2A2A;
  --text:#FFFFFF; --text-2:#B0B0B0; --text-3:#666666;
  --teal:#1D9E75; --teal-light:#0F2A22; --teal-mid:#127A5A; --teal-dark:#085041;
  --navy:#0A0F0D; --navy-light:#111816;
  --amber:#BA7517; --amber-light:#1A150D; --amber-mid:#EF9F27;
  --red:#c23a3a; --red-light:#1A0D0D; --red-dark:#7f1d1d;
  --blue:#378ADD; --blue-light:#0D1A2A;
  --purple:#7F77DD; --purple-light:#15142A;
  --radius:10px; --radius-sm:6px; --radius-lg:14px;
  --font:'DM Sans',sans-serif; --mono:'DM Mono',monospace;
  --shadow:0 1px 3px rgba(0,0,0,0.4); --shadow-md:0 4px 16px rgba(0,0,0,0.5);
}
*{box-sizing:border-box;margin:0;padding:0;font-stretch:normal;}
body{font-family:var(--font);background:var(--bg);color:var(--text);font-size:14px;line-height:1.6;min-height:100vh;-webkit-font-smoothing:antialiased;}
::-webkit-scrollbar{width:5px;height:5px;} ::-webkit-scrollbar-track{background:transparent;} ::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.15);border-radius:3px;}
.shell{display:flex;min-height:100vh;}
.sidebar{width:230px;min-height:100vh;background:var(--navy);padding:0;display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100;overflow-y:auto;border-right:1px solid rgba(255,255,255,0.05);}
.sidebar-logo{padding:20px 18px 16px;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:10px;}
.sidebar-logo img{width:28px;height:28px;object-fit:contain;filter:brightness(0) invert(1);}
.sidebar-logo-text{font-size:13px;font-weight:600;color:#fff;line-height:1.2;}
.sidebar-logo-sub{font-size:10px;color:rgba(255,255,255,0.4);letter-spacing:1px;text-transform:uppercase;}
.nav-section{padding:16px 12px 4px;font-size:9.5px;font-weight:700;text-transform:uppercase;letter-spacing:1.2px;color:rgba(255,255,255,0.3);}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 16px;cursor:pointer;font-size:13px;color:rgba(255,255,255,0.55);border:none;background:none;width:100%;text-align:left;transition:all 0.12s;border-left:2px solid transparent;}
.nav-item:hover{background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.85);}
.nav-item.active{background:rgba(29,158,117,0.18);color:#5DCAA5;border-left-color:#5DCAA5;}
.nav-icon{font-size:14px;width:18px;text-align:center;flex-shrink:0;}
.nav-badge{margin-left:auto;font-size:10px;font-family:var(--mono);background:rgba(255,255,255,0.1);padding:1px 7px;border-radius:99px;color:rgba(255,255,255,0.6);}
.nav-item.active .nav-badge{background:rgba(93,202,165,0.2);color:#5DCAA5;}
.nav-divider{height:1px;background:rgba(255,255,255,0.06);margin:8px 16px;}
.sidebar-bottom{margin-top:auto;padding:16px;border-top:1px solid rgba(255,255,255,0.06);}
.conn-status{font-size:11px;color:rgba(255,255,255,0.35);line-height:1.7;}
.conn-dot{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--red);margin-right:5px;}
.conn-dot.connected{background:#5DCAA5;}
.user-info{font-size:11px;color:rgba(255,255,255,0.5);margin-top:4px;}
.main{margin-left:230px;flex:1;min-width:0;}
.topbar{background:var(--surface);border-bottom:1px solid var(--border);padding:0 28px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
.topbar-title{font-size:15px;font-weight:600;color:var(--text);}
.topbar-sub{font-size:12px;color:var(--text-3);margin-top:1px;}
.topbar-actions{display:flex;gap:8px;align-items:center;}
.content{padding:24px 28px;}
.btn{font-family:var(--font);font-size:13px;padding:7px 14px;border-radius:var(--radius-sm);border:1px solid var(--border-md);background:var(--surface);color:var(--text);cursor:pointer;transition:all 0.15s;display:inline-flex;align-items:center;gap:5px;white-space:nowrap;}
.btn:hover{background:var(--bg);}
.btn-teal{background:var(--teal);color:#fff;border-color:var(--teal);font-weight:500;}
.btn-teal:hover{background:var(--teal-dark);border-color:var(--teal-dark);}
.btn-ghost{border-color:transparent;background:transparent;}
.btn-ghost:hover{background:var(--bg);border-color:var(--border);}
.btn-danger{color:var(--red);}
.btn-danger:hover{background:var(--red-light);border-color:#fca5a5;}
.btn-sm{padding:5px 10px;font-size:12px;}
.setup-banner{background:var(--amber-light);border:1px solid var(--amber-mid);border-radius:var(--radius);padding:11px 14px;margin-bottom:20px;font-size:12.5px;color:#fff;display:flex;align-items:center;gap:10px;}
.setup-banner p{flex:1;} .setup-banner strong{font-weight:600;}
.dash-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px;}
.dash-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;box-shadow:var(--shadow);position:relative;overflow:hidden;}
.dash-card-accent{position:absolute;top:0;left:0;right:0;height:3px;}
.dash-label{font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:0.08em;font-weight:600;margin-bottom:6px;}
.dash-value{font-size:28px;font-weight:600;line-height:1;font-family:var(--mono);color:var(--text);}
.dash-sub{font-size:11px;color:var(--text-3);margin-top:4px;}
.charts-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px;}
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;box-shadow:var(--shadow);}
.chart-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-3);margin-bottom:14px;}
.donut-wrap{display:flex;align-items:center;gap:18px;}
.donut-canvas-wrap{position:relative;flex-shrink:0;width:110px;height:110px;}
.donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;pointer-events:none;}
.donut-center-num{font-size:20px;font-weight:600;font-family:var(--mono);color:var(--text);line-height:1;}
.donut-center-sub{font-size:9px;color:var(--text-3);margin-top:2px;text-transform:uppercase;letter-spacing:0.5px;}
.donut-legend{display:flex;flex-direction:column;gap:7px;flex:1;}
.legend-item{display:flex;align-items:center;gap:8px;}
.legend-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.legend-label{font-size:11.5px;color:var(--text-2);flex:1;}
.legend-val{font-size:12px;font-weight:600;font-family:var(--mono);color:var(--text);}
.pipeline-bars{display:flex;flex-direction:column;gap:9px;}
.pipe-row{display:flex;align-items:center;gap:10px;}
.pipe-label{font-size:11.5px;color:var(--text-2);width:82px;flex-shrink:0;text-align:right;}
.pipe-track{flex:1;height:7px;background:var(--bg);border-radius:4px;overflow:hidden;}
.pipe-fill{height:100%;border-radius:4px;width:0%;transition:width 0.9s cubic-bezier(.4,0,.2,1);}
.pipe-count{font-size:11.5px;font-weight:600;font-family:var(--mono);color:var(--text);width:18px;text-align:right;flex-shrink:0;}
.tool-links{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:24px;}
.tool-link-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;display:flex;align-items:center;gap:12px;cursor:pointer;transition:all 0.15s;text-decoration:none;}
.tool-link-card:hover{border-color:var(--teal-mid);box-shadow:var(--shadow-md);transform:translateY(-1px);}
.tool-link-icon{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.tool-link-name{font-size:13px;font-weight:600;color:var(--text);}
.tool-link-sub{font-size:11px;color:var(--text-3);}
.tool-link-arrow{margin-left:auto;color:var(--text-3);font-size:14px;}
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.section-title{font-size:15px;font-weight:600;color:var(--text);}
.section-sub{font-size:12px;color:var(--text-3);margin-top:2px;}
.sheet-wrap{margin-bottom:28px;}
.sheet-client-header{display:flex;align-items:center;gap:8px;margin-bottom:8px;padding:0 2px;}
.sheet-client-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
.sheet-client-name{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--text-2);}
.sheet-client-meta{font-size:11px;color:var(--text-3);font-family:var(--mono);}
.sheet-table{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;}
.proj-head,.proj-row,.ops-head,.ops-row{display:grid;grid-template-columns:180px 110px 1fr 1fr 110px 100px;}
.tend-head,.tend-row{display:grid;grid-template-columns:160px 150px 1fr 160px 110px 110px;}
.sheet-head-row{background:var(--bg);border-bottom:2px solid var(--border-md);}
.sh-cell{padding:8px 12px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-3);border-right:1px solid var(--border);}
.sh-cell:last-child{border-right:none;}
.sheet-row-item{border-bottom:1px solid var(--border);cursor:pointer;transition:background 0.1s;align-items:stretch;}
.sheet-row-item:last-child{border-bottom:none;}
.sheet-row-item:hover{background:#1a1a1a;}
.sd-cell{padding:10px 12px;font-size:13px;color:var(--text);border-right:1px solid var(--border);display:flex;align-items:center;overflow:hidden;}
.sd-cell:last-child{border-right:none;}
.sd-cell-name{flex-direction:column;align-items:flex-start;gap:2px;position:relative;padding-left:16px;}
.sd-cell-bar{position:absolute;left:0;top:0;bottom:0;width:3px;}
.sd-cell-title{font-size:13px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%;}
.sd-cell-sub{font-size:11px;color:var(--text-3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%;}
.sd-cell-text{font-size:12.5px;color:var(--text-2);line-height:1.5;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;}
.sd-cell-link{font-size:12px;color:var(--blue);text-decoration:none;display:flex;align-items:center;gap:3px;}
.sd-cell-link:hover{text-decoration:underline;}
.badge{font-size:10.5px;font-weight:500;padding:2px 8px;border-radius:99px;white-space:nowrap;display:inline-block;}
.b-ontrack{background:#0F2A22;color:#5DCAA5;}
.b-waiting{background:#0D1A2A;color:#5B9FD8;}
.b-blocked{background:#1A0D0D;color:#E65A5A;}
.b-completed{background:#0F2A22;color:#5DCAA5;}
.b-submitted{background:#15142A;color:#9B94E8;}
.b-negotiating{background:#1A150D;color:#E8C36A;}
.b-won{background:#0F2A22;color:#5DCAA5;}
.b-lost{background:#1A0D0D;color:#E65A5A;}
.b-rfq{background:#0D1A2A;color:#5B9FD8;}
.b-rfx{background:#15142A;color:#9B94E8;}
.b-direct{background:#1A150D;color:#E8C36A;}
.sb{font-size:10px;font-weight:600;padding:2px 7px;border-radius:99px;text-transform:uppercase;letter-spacing:0.3px;white-space:nowrap;}
.sb-trucking{background:#0F2A22;color:#5DCAA5;}
.sb-warehouse{background:#0D1A2A;color:#5B9FD8;}
.sb-tech{background:#15142A;color:#9B94E8;}
.sb-advisory{background:#1A150D;color:#E8C36A;}
.sb-distribution{background:#1A0D15;color:#D86BA0;}
.sb-other{background:#1A1A1A;color:#999;}
.dl-text{font-size:12px;font-family:var(--mono);color:var(--text-2);}
.dl-urgent{color:#E65A5A;font-weight:600;}
.dl-overdue{color:#E65A5A;font-weight:600;}
.toolbar{display:flex;align-items:center;gap:7px;margin-bottom:16px;flex-wrap:wrap;}
.filter-pill{padding:4px 12px;border-radius:99px;font-size:12px;font-weight:500;cursor:pointer;border:1px solid var(--border-md);background:var(--surface);color:var(--text-2);transition:all 0.12s;user-select:none;}
.filter-pill:hover{border-color:var(--teal-mid);color:var(--teal);}
.filter-pill.active{border-color:var(--teal);color:#fff;background:var(--teal-dark);}
.search-input{padding:6px 11px;border:1px solid var(--border-md);border-radius:var(--radius-sm);font-size:13px;font-family:var(--font);background:var(--surface);color:var(--text);width:180px;outline:none;transition:border 0.15s;}
.search-input:focus{border-color:var(--teal-mid);}
.empty-box{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);text-align:center;padding:3rem 1rem;color:var(--text-3);}
.empty-box h3{font-size:14px;font-weight:600;color:var(--text-2);margin-bottom:6px;}
.empty-box p{font-size:12.5px;margin-bottom:14px;}
.filter-dropdown{position:relative;display:inline-block;}
.filter-dropdown-btn{display:flex;align-items:center;gap:6px;padding:4px 12px;border-radius:99px;font-size:12px;font-weight:500;cursor:pointer;border:1px solid var(--border-md);background:var(--surface);color:var(--text-2);transition:all 0.12s;user-select:none;}
.filter-dropdown-btn:hover{border-color:var(--teal-mid);color:var(--teal);}
.filter-dropdown-btn.has-filter{border-color:var(--teal);color:#fff;background:var(--teal-dark);}
.filter-dropdown-btn .arrow{font-size:9px;transition:transform 0.15s;}
.filter-dropdown-btn.open .arrow{transform:rotate(180deg);}
.filter-dropdown-menu{display:none;position:absolute;top:calc(100% + 6px);left:0;background:var(--surface);border:1px solid var(--border-md);border-radius:var(--radius);box-shadow:var(--shadow-md);padding:10px;z-index:200;min-width:200px;}
.filter-dropdown-menu.open{display:block;}
.fdm-section{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-3);margin-bottom:6px;margin-top:10px;}
.fdm-section:first-child{margin-top:0;}
.fdm-year-row{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:4px;}
.fdm-year-btn{padding:3px 10px;border-radius:99px;font-size:12px;font-weight:500;cursor:pointer;border:1px solid var(--border-md);background:var(--bg);color:var(--text-2);transition:all 0.12s;}
.fdm-year-btn:hover{border-color:var(--teal-mid);color:var(--teal);}
.fdm-year-btn.sel{border-color:var(--teal);color:#fff;background:var(--teal-dark);}
.fdm-months{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;}
.fdm-month-btn{padding:4px 6px;border-radius:6px;font-size:11px;font-weight:500;cursor:pointer;border:1px solid var(--border-md);background:var(--bg);color:var(--text-2);transition:all 0.12s;text-align:center;}
.fdm-month-btn:hover{border-color:var(--teal-mid);color:var(--teal);}
.fdm-month-btn.sel{border-color:var(--teal);color:#fff;background:var(--teal-dark);}
.fdm-footer{display:flex;justify-content:space-between;align-items:center;margin-top:10px;padding-top:8px;border-top:1px solid var(--border);}
.fdm-clear{font-size:11.5px;color:var(--text-3);cursor:pointer;background:none;border:none;font-family:var(--font);}
.fdm-clear:hover{color:var(--red);}
.fdm-apply{font-size:12px;font-weight:600;color:#fff;background:var(--teal);border:none;border-radius:6px;padding:5px 14px;cursor:pointer;font-family:var(--font);}
.fdm-apply:hover{background:var(--teal-dark);}
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:500;align-items:center;justify-content:center;padding:1rem;}
.modal-overlay.open{display:flex;}
.modal{background:var(--surface);border-radius:var(--radius-lg);width:100%;max-width:680px;max-height:90vh;overflow-y:auto;box-shadow:0 24px 64px rgba(0,0,0,0.6);border:1px solid var(--border);animation:slideUp 0.18s ease;}
.modal-sm{max-width:480px;}
.modal-lg{max-width:820px;}
@keyframes slideUp{from{transform:translateY(10px);opacity:0;}to{transform:translateY(0);opacity:1;}}
.modal-header{padding:1.25rem 1.5rem 1rem;display:flex;align-items:flex-start;justify-content:space-between;position:sticky;top:0;background:var(--surface);border-radius:var(--radius-lg) var(--radius-lg) 0 0;border-bottom:1px solid var(--border);margin-bottom:1.25rem;}
.modal-title{font-size:16px;font-weight:600;}
.modal-sub{font-size:12px;color:var(--text-3);margin-top:2px;}
.modal-close{background:none;border:none;font-size:18px;cursor:pointer;color:var(--text-3);line-height:1;padding:2px 5px;border-radius:5px;}
.modal-close:hover{background:var(--bg);color:var(--text);}
.modal-body{padding:0 1.5rem 1.5rem;}
.modal-footer{padding:1rem 1.5rem;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;position:sticky;bottom:0;background:var(--surface);border-radius:0 0 var(--radius-lg) var(--radius-lg);}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.form-group{display:flex;flex-direction:column;gap:4px;}
.form-group.full{grid-column:1/-1;}
.form-label{font-size:11px;font-weight:600;color:var(--text-2);text-transform:uppercase;letter-spacing:0.04em;}
input,select,textarea{font-family:var(--font);font-size:13px;padding:8px 10px;border:1px solid var(--border-md);border-radius:var(--radius-sm);background:var(--bg);color:var(--text);outline:none;transition:border 0.15s,background 0.15s;width:100%;}
input:focus,select:focus,textarea:focus{border-color:var(--teal-mid);background:#111;}
textarea{resize:vertical;min-height:68px;line-height:1.5;}
.section-sep{margin:16px 0 10px;padding-bottom:6px;border-bottom:1px solid var(--border);font-size:12px;font-weight:700;color:var(--text);display:flex;align-items:center;gap:6px;}
.milestone-list{display:flex;flex-direction:column;gap:5px;}
.milestone-item{display:grid;grid-template-columns:1fr 130px auto;gap:8px;align-items:center;padding:7px 9px;background:var(--bg);border-radius:var(--radius-sm);border:1px solid transparent;}
.milestone-item:hover{border-color:var(--border);}
.milestone-item input{padding:5px 8px;}
.m-del{background:none;border:none;cursor:pointer;color:var(--text-3);font-size:14px;padding:2px;}
.m-del:hover{color:var(--red);}
.add-m-btn{display:flex;align-items:center;justify-content:center;gap:5px;padding:6px;font-size:12px;color:var(--teal);background:none;border:1px dashed var(--teal-mid);border-radius:var(--radius-sm);cursor:pointer;width:100%;font-family:var(--font);margin-top:3px;}
.add-m-btn:hover{background:var(--teal-light);}
.report-preview{background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:16px;margin-top:12px;font-size:12.5px;line-height:1.7;color:var(--text);}
.report-table{width:100%;border-collapse:collapse;font-size:12px;margin-bottom:12px;}
.report-table th{background:var(--teal-light);color:var(--teal);padding:7px 10px;text-align:left;border:1px solid var(--teal-mid);font-weight:600;}
.report-table td{padding:7px 10px;border:1px solid var(--border);vertical-align:top;color:var(--text);}
.report-table tr:nth-child(even) td{background:#111;}
.report-section-title{font-size:13px;font-weight:700;color:var(--text);margin:12px 0 8px;padding-bottom:5px;border-bottom:2px solid var(--teal-mid);}
.gs-steps{background:var(--teal-light);border:1px solid var(--teal-mid);border-radius:var(--radius);padding:12px 14px;margin-bottom:14px;font-size:12.5px;color:var(--teal);line-height:1.9;}
.script-box{background:#050505;border-radius:var(--radius-sm);padding:12px 14px;font-size:11px;font-family:var(--mono);color:#888;line-height:1.7;overflow:auto;white-space:pre;max-height:240px;margin-top:10px;}
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;}
.detail-block .dl-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--text-3);margin-bottom:5px;}
.detail-block .dl-value{font-size:13px;color:var(--text);line-height:1.6;}
.detail-block a{color:var(--teal);text-decoration:none;word-break:break-all;font-size:13px;}
.detail-block a:hover{text-decoration:underline;}
.prog-sel{display:flex;gap:5px;flex-wrap:wrap;}
.prog-opt{padding:4px 11px;border-radius:99px;font-size:11.5px;font-weight:500;cursor:pointer;border:1px solid var(--border-md);background:var(--surface);color:var(--text-2);transition:all 0.12s;}
.prog-opt.sel{border-color:transparent;}
.milestone-view{display:flex;flex-direction:column;gap:5px;}
.mv-item{display:flex;align-items:center;gap:10px;padding:7px 10px;background:var(--bg);border-radius:var(--radius-sm);font-size:13px;}
.mv-label{flex:1;color:var(--text);}
.mv-date{font-size:12px;font-family:var(--mono);color:var(--text-3);}
.mv-past{text-decoration:line-through;opacity:0.5;}
.toast{position:fixed;bottom:1.25rem;right:1.25rem;background:var(--navy);color:#fff;padding:9px 16px;border-radius:var(--radius);font-size:13px;z-index:999;opacity:0;transition:opacity 0.2s;pointer-events:none;box-shadow:var(--shadow-md);}
.toast.show{opacity:1;}
.conn-badge{display:inline-flex;align-items:center;gap:4px;background:var(--teal-light);color:var(--teal);font-size:11.5px;font-weight:600;padding:3px 9px;border-radius:99px;}
.week-cell{font-size:12px;color:var(--text-2);line-height:1.5;overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;}
.lock-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:600;display:flex;align-items:center;justify-content:center;padding:1rem;}
.lock-box{background:var(--surface);border-radius:var(--radius-lg);padding:2rem 2.5rem;max-width:420px;width:100%;text-align:center;box-shadow:0 24px 64px rgba(0,0,0,0.7);border:1px solid var(--border);}
.lock-icon{font-size:40px;margin-bottom:12px;}
.lock-title{font-size:16px;font-weight:700;color:var(--text);margin-bottom:8px;}
.lock-email{font-size:14px;color:var(--teal);font-weight:600;background:var(--teal-light);padding:4px 12px;border-radius:99px;display:inline-block;margin-bottom:10px;}
.lock-sub{font-size:13px;color:var(--text-3);margin-bottom:18px;}
.lock-countdown{font-size:22px;font-weight:700;font-family:var(--mono);color:var(--amber);margin-bottom:16px;}
.history-table{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;}
.hist-head,.hist-row{display:grid;grid-template-columns:150px 240px 80px 70px 1fr;}
.hist-action-add{color:var(--teal);background:var(--teal-light);font-size:10px;font-weight:700;padding:2px 7px;border-radius:99px;text-transform:uppercase;}
.hist-action-edit{color:var(--blue);background:var(--blue-light);font-size:10px;font-weight:700;padding:2px 7px;border-radius:99px;text-transform:uppercase;}
.hist-action-delete{color:var(--red);background:var(--red-light);font-size:10px;font-weight:700;padding:2px 7px;border-radius:99px;text-transform:uppercase;}
.hist-action-status{color:var(--amber);background:var(--amber-light);font-size:10px;font-weight:700;padding:2px 7px;border-radius:99px;text-transform:uppercase;}
.user-row{display:flex;gap:8px;align-items:center;padding:8px;background:var(--bg);border-radius:var(--radius-sm);margin-bottom:6px;}
.user-row input,.user-row select{padding:6px 8px;}
.health-badge{display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:99px;font-size:12px;font-weight:600;}
.h-healthy{background:#0F2A22;color:#5DCAA5;}
.h-risk{background:#1A150D;color:#E8C36A;}
.h-unhealthy{background:#1A0D0D;color:#E65A5A;}
#login-screen{position:fixed;inset:0;background:var(--bg);z-index:9999;display:flex;align-items:center;justify-content:center;}
.login-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:2.5rem 2rem;width:100%;max-width:380px;text-align:center;}
.login-logo{font-size:24px;font-weight:700;margin-bottom:8px;}
.login-sub{font-size:12px;color:var(--text-3);margin-bottom:24px;text-transform:uppercase;letter-spacing:2px;}
@media(max-width:900px){
.sidebar{display:none;} .main{margin-left:0;}
.dash-grid{grid-template-columns:1fr 1fr;}
.tool-links{grid-template-columns:1fr;}
.form-grid{grid-template-columns:1fr;}
.proj-head,.proj-row,.ops-head,.ops-row{grid-template-columns:1fr 90px 80px;}
.sh-cell:nth-child(n+4),.sd-cell:nth-child(n+4){display:none;}
}
</style>
</head>
<body>

<!-- LOGIN SCREEN -->
<div id="login-screen">
  <div class="login-card">
    <div class="login-logo">OLS</div>
    <div class="login-sub">Project-Ops</div>
    <div class="form-group" style="margin-bottom:16px;text-align:left;">
      <label class="form-label">Access Code</label>
      <input type="password" id="login-code" placeholder="Enter your code" maxlength="10" autocomplete="off">
    </div>
    <button class="btn btn-teal" style="width:100%;" onclick="handleLogin()">Sign In</button>
    <div id="login-error" style="color:var(--red);font-size:12px;margin-top:12px;display:none;">Invalid code. Please try again.</div>
  </div>
</div>

<div class="shell">
<aside class="sidebar">
<div class="sidebar-logo">
<img src="data:image/png;base64,......" alt="OLS Logo">
<div>
<div class="sidebar-logo-text">One Logistics Solutions</div>
<div class="sidebar-logo-sub">Project-Ops</div>
</div>
</div>
<div class="nav-section">Main</div>
<button class="nav-item active" onclick="showPage('dashboard',this)"><span class="nav-icon">▦</span> Dashboard</button>
<div class="nav-section">Business</div>
<button class="nav-item" onclick="showPage('projects',this)"><span class="nav-icon">◈</span> Projects<span class="nav-badge" id="nb-proj">0</span></button>
<button class="nav-item" onclick="showPage('tenders',this)"><span class="nav-icon">◎</span> Tenders<span class="nav-badge" id="nb-tend">0</span></button>
<button class="nav-item" onclick="showPage('operations',this)"><span class="nav-icon">⚙</span> Operations<span class="nav-badge" id="nb-ops">0</span></button>
<div class="nav-divider"></div>
<div class="nav-section">Tools</div>
<button class="nav-item" onclick="showPage('report',this)"><span class="nav-icon">▤</span> Weekly Report</button>
<button class="nav-item" onclick="showPage('history',this)"><span class="nav-icon">🕐</span> History<span class="nav-badge" id="nb-hist">0</span></button>
<div class="nav-divider"></div>
<div class="nav-section">Settings</div>
<button class="nav-item" onclick="openGSModal()"><span class="nav-icon">⚙</span> Google Sheets</button>
<div class="sidebar-bottom">
<div class="conn-status" id="sidebar-conn">
<span class="conn-dot" id="conn-dot"></span>
<span id="conn-label">Not connected</span>
</div>
<div class="user-info" id="user-display">Guest</div>
</div>
</aside>

<div class="main">
<div class="topbar">
<div>
<div class="topbar-title" id="topbar-title">Dashboard</div>
<div class="topbar-sub" id="topbar-sub">OLS Project-Ops — Overview</div>
</div>
<div class="topbar-actions">
<div id="gs-badge"></div>
<button class="btn btn-ghost btn-sm" onclick="exportCSV()">↑ Export CSV</button>
<button class="btn btn-teal btn-sm" id="topbar-action-btn" onclick="openAddProject()">+ New Entry</button>
<button class="btn btn-danger btn-sm" onclick="logout()" style="margin-left:8px;">Logout</button>
</div>
</div>

<div class="content">
<div class="setup-banner" id="setup-banner" style="display:none;">
<span style="font-size:18px;">📊</span>
<p><strong>Connect Google Sheets</strong> to sync all data. Click Settings → Google Sheets.</p>
<button class="btn btn-sm" style="background:var(--amber);color:#fff;border:none;" onclick="openGSModal()">Connect Now</button>
</div>

<!-- DASHBOARD -->
<div id="page-dashboard">
<div class="dash-grid">
<div class="dash-card"><div class="dash-card-accent" style="background:var(--teal);"></div><div class="dash-label">Active Clients</div><div class="dash-value" id="d-clients">0</div><div class="dash-sub">projects running</div></div>
<div class="dash-card"><div class="dash-card-accent" style="background:var(--blue);"></div><div class="dash-label">Tenders In Flight</div><div class="dash-value" id="d-tenders" style="color:var(--blue);">0</div><div class="dash-sub">open RFQ / RFX</div></div>
<div class="dash-card"><div class="dash-card-accent" style="background:var(--amber);"></div><div class="dash-label">Due This Week</div><div class="dash-value" id="d-week" style="color:var(--amber);">0</div><div class="dash-sub">deadlines approaching</div></div>
<div class="dash-card"><div class="dash-card-accent" style="background:var(--red);"></div><div class="dash-label">Blocked Items</div><div class="dash-value" id="d-blocked" style="color:var(--red);">0</div><div class="dash-sub">need attention</div></div>
</div>

<div class="charts-row">
<div class="chart-card">
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
<div class="chart-title" style="margin-bottom:0;">Portfolio Health</div>
<div id="health-badge" class="health-badge h-healthy">● Healthy</div>
</div>
<div class="donut-wrap">
<div class="donut-canvas-wrap"><canvas id="donut-chart" width="110" height="110"></canvas><div class="donut-center"><div class="donut-center-num" id="donut-total">0</div><div class="donut-center-sub">total</div></div></div>
<div class="donut-legend" id="donut-legend"></div>
</div>
</div>
<div class="chart-card">
<div class="chart-title">Tender Pipeline</div>
<div class="pipeline-bars" id="pipeline-bars"></div>
</div>
</div>

<div class="section-header">
<div><div class="section-title">This Week's Focus</div><div class="section-sub">Items due within 7 days or blocked</div></div>
</div>
<div id="dash-focus-list"><div class="empty-box"><h3>No urgent items</h3><p>All clear — no deadlines within 7 days</p></div></div>
</div>

<!-- PROJECTS -->
<div id="page-projects" style="display:none;">
<div class="section-header">
<div><div class="section-title">Projects</div><div class="section-sub">Strategic client workstreams</div></div>
<div style="display:flex;gap:8px;"><input class="search-input" type="text" placeholder="Search…" id="proj-search" oninput="renderProjects()"><button class="btn btn-teal btn-sm" onclick="openAddProject()">+ New Project</button></div>
</div>
<div class="toolbar">
<div class="filter-pill active" onclick="setProjFilter('all',this)">All</div>
<div class="filter-pill" onclick="setProjFilter('Trucking',this)">Trucking</div>
<div class="filter-pill" onclick="setProjFilter('Warehousing',this)">Warehousing</div>
<div class="filter-pill" onclick="setProjFilter('Technology',this)">Technology</div>
<div class="filter-pill" onclick="setProjFilter('Advisory',this)">Advisory</div>
<div class="filter-pill" onclick="setProjFilter('Distribution',this)">Distribution</div>
<div class="filter-pill" onclick="setProjFilter('Blocked',this)">Blocked</div>
</div>
<div id="proj-board"></div>
</div>

<!-- TENDERS -->
<div id="page-tenders" style="display:none;">
<div class="section-header">
<div><div class="section-title">Tenders</div><div class="section-sub">RFQ, RFX and direct negotiations</div></div>
<div style="display:flex;gap:8px;"><input class="search-input" type="text" placeholder="Search…" id="tend-search" oninput="renderTenders()"><button class="btn btn-teal btn-sm" onclick="openAddTender()">+ New Tender</button></div>
</div>
<div class="toolbar">
<div class="filter-pill active" onclick="setTendFilter('all',this)">All</div>
<div class="filter-pill" onclick="setTendFilter('Upcoming',this)">Upcoming</div>
<div class="filter-pill" onclick="setTendFilter('Submitted',this)">Submitted</div>
<div class="filter-pill" onclick="setTendFilter('Negotiating',this)">Negotiating</div>
<div class="filter-pill" onclick="setTendFilter('Won',this)">Won</div>
<div class="filter-pill" onclick="setTendFilter('Lost',this)">Lost</div>
</div>
<div class="sheet-table">
<div class="tend-head sheet-head-row">
<div class="sh-cell">Client</div><div class="sh-cell">Type</div><div class="sh-cell">Key Milestones</div><div class="sh-cell">Document</div><div class="sh-cell">Owner</div><div class="sh-cell">Status</div>
</div>
<div id="tend-board"></div>
</div>
</div>

<!-- OPERATIONS -->
<div id="page-operations" style="display:none;">
<div class="section-header">
<div><div class="section-title">Operations</div><div class="section-sub">Recurring operational activities (trucking, warehouse, etc.)</div></div>
<div style="display:flex;gap:8px;"><input class="search-input" type="text" placeholder="Search…" id="ops-search" oninput="renderOperations()"><button class="btn btn-teal btn-sm" onclick="openAddOperation()">+ New Operation</button></div>
</div>
<div class="toolbar">
<div class="filter-pill active" onclick="setOpsFilter('all',this)">All</div>
<div class="filter-pill" onclick="setOpsFilter('Trucking',this)">Trucking</div>
<div class="filter-pill" onclick="setOpsFilter('Warehousing',this)">Warehousing</div>
<div class="filter-pill" onclick="setOpsFilter('Technology',this)">Technology</div>
<div class="filter-pill" onclick="setOpsFilter('Advisory',this)">Advisory</div>
<div class="filter-pill" onclick="setOpsFilter('Distribution',this)">Distribution</div>
<div class="filter-pill" onclick="setOpsFilter('Blocked',this)">Blocked</div>
</div>
<div id="ops-board"></div>
</div>

<!-- WEEKLY REPORT -->
<div id="page-report" style="display:none;">
<div class="section-header">
<div><div class="section-title">Weekly Report Generator</div><div class="section-sub">Auto-fills Last Week from previous entries. Write This Week updates, then export.</div></div>
<div style="display:flex;gap:8px;"><button class="btn btn-ghost btn-sm" onclick="previewReport()">Preview</button><button class="btn btn-teal btn-sm" onclick="exportReport()">↓ Export .txt</button></div>
</div>
<div style="background:var(--teal-light);border:1px solid var(--teal-mid);border-radius:var(--radius);padding:11px 14px;margin-bottom:20px;font-size:12.5px;color:var(--teal);">
<strong>How it works:</strong> "Last Week" is auto-filled from what you entered as "This Week" previously. Fill in "This Week" updates below, then click Export to generate your Word document.
</div>
<div class="report-section-title">Active Projects</div>
<div id="report-proj-table"></div>
<div class="report-section-title" style="margin-top:20px;">Tenders</div>
<div id="report-tend-table"></div>
<div class="report-section-title" style="margin-top:20px;">Operations</div>
<div id="report-ops-table"></div>
<div id="report-preview" style="display:none;margin-top:20px;">
<div class="report-section-title">Preview</div>
<div class="report-preview" id="report-preview-content"></div>
</div>
</div>

<!-- HISTORY -->
<div id="page-history" style="display:none;">
<div class="section-header">
<div><div class="section-title">Edit History</div><div class="section-sub">Last 50 edits across all entities</div></div>
</div>
<div id="history-board"><div class="empty-box"><h3>No history yet</h3><p>Changes will appear here after the first edit</p></div></div>
</div>

<!-- SETTINGS -->
<div id="page-settings" style="display:none;">
<div class="section-header">
<div><div class="section-title">Settings</div><div class="section-sub">Google Sheets connection & User management</div></div>
</div>
<div class="gs-steps">
<strong>Setup (one time):</strong><br>
1. Open your Sheet → Extensions → Apps Script<br>
2. Paste the script below → Save → Deploy as Web App<br>
3. Execute as: Me · Who has access: Anyone within One Logistics Solutions<br>
4. Copy the Web App URL and paste below
</div>
<div class="form-group" style="margin-bottom:10px;">
<label class="form-label">Web App URL</label>
<input type="url" id="gs-url" placeholder="https://script.google.com/macros/s/…">
</div>
<details style="margin-bottom:14px;">
<summary style="cursor:pointer;font-size:13px;font-weight:600;color:var(--teal);padding:4px 0;">📋 Apps Script Code</summary>
<div class="script-box" id="gs-script"></div>
<button class="btn btn-ghost btn-sm" style="margin-top:7px;" onclick="copyScript()">Copy Script</button>
</details>
<button class="btn btn-teal" onclick="saveGS()">Save & Connect</button>

<div id="users-panel" style="margin-top:24px;display:none;">
<div class="section-sep">User Management (Admin Only)</div>
<div style="margin-bottom:12px;display:flex;justify-content:space-between;align-items:center;">
<div style="font-weight:600;">Team Members</div>
<button class="btn btn-teal btn-sm" onclick="addUserRow()">+ Add User</button>
</div>
<div id="users-list" style="display:flex;flex-direction:column;gap:8px;max-height:300px;overflow-y:auto;"></div>
<button class="btn btn-teal" style="margin-top:12px;" onclick="saveUsers()">Save Users</button>
</div>
</div>

</div><!-- /content -->
</div><!-- /main -->
</div><!-- /shell -->

<!-- MODALS -->
<div class="modal-overlay" id="proj-modal" onclick="overlayClose(event,'proj-modal')">
<div class="modal">
<div class="modal-header"><div><div class="modal-title" id="proj-modal-title">New Project</div><div class="modal-sub">Add a strategic client workstream</div></div><button class="modal-close" onclick="closeModal('proj-modal')">✕</button></div>
<div class="modal-body">
<div class="form-grid">
<div class="form-group"><label class="form-label">Client Name *</label><input type="text" id="pf-client" placeholder="e.g. Mofmofriends, Stojo"></div>
<div class="form-group"><label class="form-label">Workstream *</label><input type="text" id="pf-workstream" placeholder="e.g. Retailer, Marketing"></div>
<div class="form-group"><label class="form-label">Service Line</label><select id="pf-service"><option>Trucking</option><option>Warehousing</option><option>Technology</option><option>Advisory</option><option>Distribution</option><option>Other</option></select></div>
<div class="form-group"><label class="form-label">Project Owner</label><input type="text" id="pf-owner" placeholder="e.g. Prambani Chim"></div>
<div class="form-group"><label class="form-label">Region</label><select id="pf-region"><option>Jakarta</option><option>Surabaya</option><option>Nationwide</option><option>Cross-border SEA</option><option>Other</option></select></div>
<div class="form-group"><label class="form-label">Status</label><select id="pf-status"><option>On Track</option><option>Waiting</option><option>Blocked</option><option>Completed</option></select></div>
<div class="form-group full"><label class="form-label">This Week Plan *</label><textarea id="pf-thisweek" placeholder="What is happening this week?"></textarea></div>
<div class="form-group full"><label class="form-label">Key Dates / Deadlines</label><input type="text" id="pf-dates" placeholder="e.g. Gramedia: 14 Apr"></div>
<div class="form-group"><label class="form-label">Deadline Date</label><input type="date" id="pf-deadline"></div>
<div class="form-group"><label class="form-label">Document / Drive Link</label><input type="url" id="pf-link" placeholder="https://drive.google.com/…"></div>
<div class="form-group full"><label class="form-label">Notes</label><textarea id="pf-notes" placeholder="Additional context…" style="min-height:52px;"></textarea></div>
</div>
</div>
<div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('proj-modal')">Cancel</button><button class="btn btn-teal" onclick="saveProject()">Save Entry</button></div>
</div>
</div>

<div class="modal-overlay" id="tend-modal" onclick="overlayClose(event,'tend-modal')">
<div class="modal">
<div class="modal-header"><div><div class="modal-title" id="tend-modal-title">New Tender</div><div class="modal-sub">Track RFQ, RFX or direct negotiation</div></div><button class="modal-close" onclick="closeModal('tend-modal')">✕</button></div>
<div class="modal-body">
<div class="form-grid">
<div class="form-group"><label class="form-label">Client / Company *</label><input type="text" id="tf-client" placeholder="e.g. DHL, L'Oreal"></div>
<div class="form-group"><label class="form-label">Tender Type</label><select id="tf-type"><option>RFQ</option><option>RFX</option><option>Direct Negotiation</option></select></div>
<div class="form-group"><label class="form-label">Owner</label><input type="text" id="tf-owner" placeholder="Responsible person"></div>
<div class="form-group"><label class="form-label">Status</label><select id="tf-status"><option>Upcoming</option><option>Submitted</option><option>Negotiating</option><option>Won</option><option>Lost</option></select></div>
<div class="form-group full"><label class="form-label">Document / Drive Link</label><input type="url" id="tf-link" placeholder="https://drive.google.com/…"></div>
<div class="form-group full"><label class="form-label">Notes</label><textarea id="tf-notes" placeholder="e.g. Need Halal certification…" style="min-height:52px;"></textarea></div>
</div>
<div class="section-sep" style="margin-top:16px;">Key Milestones</div>
<div class="milestone-list" id="milestone-editor"></div>
<button class="add-m-btn" onclick="addMilestone()">＋ Add Milestone</button>
</div>
<div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('tend-modal')">Cancel</button><button class="btn btn-teal" onclick="saveTender()">Save Tender</button></div>
</div>
</div>

<div class="modal-overlay" id="ops-modal" onclick="overlayClose(event,'ops-modal')">
<div class="modal">
<div class="modal-header"><div><div class="modal-title" id="ops-modal-title">New Operation</div><div class="modal-sub">Add recurring operational activity</div></div><button class="modal-close" onclick="closeModal('ops-modal')">✕</button></div>
<div class="modal-body">
<div class="form-grid">
<div class="form-group"><label class="form-label">Client Name *</label><input type="text" id="of-client" placeholder="e.g. Mofmofriends, Stojo"></div>
<div class="form-group"><label class="form-label">Activity *</label><input type="text" id="of-workstream" placeholder="e.g. Daily Trucking Run, Warehouse Audit"></div>
<div class="form-group"><label class="form-label">Service Line</label><select id="of-service"><option>Trucking</option><option>Warehousing</option><option>Technology</option><option>Advisory</option><option>Distribution</option><option>Other</option></select></div>
<div class="form-group"><label class="form-label">Owner</label><input type="text" id="of-owner" placeholder="e.g. Prambani Chim"></div>
<div class="form-group"><label class="form-label">Region</label><select id="of-region"><option>Jakarta</option><option>Surabaya</option><option>Nationwide</option><option>Cross-border SEA</option><option>Other</option></select></div>
<div class="form-group"><label class="form-label">Status</label><select id="of-status"><option>On Track</option><option>Waiting</option><option>Blocked</option><option>Completed</option></select></div>
<div class="form-group full"><label class="form-label">This Week Update *</label><textarea id="of-thisweek" placeholder="What is happening this week?"></textarea></div>
<div class="form-group full"><label class="form-label">Key Dates / Deadlines</label><input type="text" id="of-dates" placeholder="e.g. Weekly every Monday"></div>
<div class="form-group"><label class="form-label">Deadline Date</label><input type="date" id="of-deadline"></div>
<div class="form-group"><label class="form-label">Document / Drive Link</label><input type="url" id="of-link" placeholder="https://drive.google.com/…"></div>
<div class="form-group full"><label class="form-label">Notes</label><textarea id="of-notes" placeholder="Additional context…" style="min-height:52px;"></textarea></div>
</div>
</div>
<div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('ops-modal')">Cancel</button><button class="btn btn-teal" onclick="saveOperation()">Save Entry</button></div>
</div>
</div>

<div class="modal-overlay" id="detail-modal" onclick="overlayClose(event,'detail-modal')">
