:140px;">Stage / Activity</th><th style="background:var(--teal-light);color:var(--teal);padding:7px 10px;border:1px solid var(--teal-mid);">Details / Deadline</th></tr></thead><tbody>${tendRows || '<tr><td colspan="3" style="padding:10px;text-align:center;color:#888;">No tenders</td></tr>'}</tbody></table>`;
  preview.style.display = ''; showToast('✓ Preview generated');
}
function exportReport() {
  projects.forEach(p => { const el = document.getElementById('tw-' + p.id); if (el) p.thisweek = el.value; });
  operations.forEach(o => { const el = document.getElementById('tow-' + o.id); if (el) o.thisweek = el.value; });
  save();
  const today = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  const groupedP = {}; projects.forEach(p => { if (!groupedP[p.client]) groupedP[p.client] = []; groupedP[p.client].push(p); });
  const groupedO = {}; operations.forEach(o => { if (!groupedO[o.client]) groupedO[o.client] = []; groupedO[o.client].push(o); });
  let doc = `OLS Weekly Report — ${today}\nTHIS WEEK\nActive Projects\nProject/Customer\tStage/Activity\tDetails/Deadline\n`;
  Object.keys(groupedP).forEach(client => { groupedP[client].forEach((p, i) => { doc += `${i === 0 ? client : ''}\t${p.workstream}\t${document.getElementById('tw-' + p.id)?.value || p.thisweek || '—'}\n`; }); });
  doc += '\nOperations\nClient\tActivity\tDetails/Deadline\n';
  Object.keys(groupedO).forEach(client => { groupedO[client].forEach((o, i) => { doc += `${i === 0 ? client : ''}\t${o.workstream}\t${document.getElementById('tow-' + o.id)?.value || o.thisweek || '—'}\n`; }); });
