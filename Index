function removeUserRow(btn) {
  btn.closest('.user-row').remove();
}
async function saveUsers() {
  if (!isAdmin()) { showToast('⚠ Admin only'); return; }
  const rows = document.querySelectorAll('#users-list .user-row');
  const updatedUsers = [];
  for (const row of rows) {
    const userId = row.dataset.userid.startsWith('new_') ? 'u_' + Math.random().toString(36).substr(2, 9) : row.dataset.userid;
    const name = row.querySelector('.u-name').value.trim();
    const email = row.querySelector('.u-email').value.trim();
    const role = row.querySelector('.u-role').value;
    const newCode = row.querySelector('.u-code').value.trim();
    if (!name || !email) { showToast('⚠ Name and Email required'); return; }
    const existing = users.find(u => u.userId === userId);
    const codeHash = newCode ? computeSHA256(newCode) : (existing ? existing.codeHash : '');
    if (!codeHash && !newCode) { showToast('⚠ New code required for new users'); return; }
    updatedUsers.push({ userId, name, email, role, codeHash, active: true });
  }
  try {
    await apiPost('manageUsers', { users: updatedUsers });
    users = updatedUsers;
    showToast('✓ Users saved');
    renderUsersList();
  } catch (err) {
    showToast('✗ Failed: ' + err.message);
  }
}

